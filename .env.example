# .env — API-Schlüssel für HeadHunter Agent
# 
# Kopiere diese Datei zu .env und trage deine Schlüssel ein:
#   cp .env.example .env
#
# .env ist in .gitignore — wird NICHT ins Git-Repository hochgeladen!

# === MISTRAL AI (Empfohlen — beste deutsche Textqualität) ===
# Kostenlos registrieren: https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# === OPENROUTER (Kostenlos — 200 Requests/Tag) ===
# Registrieren: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# === OPENAI (Optional — Pay-as-you-go) ===
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# === OLLAMA (Optional — Lokales Modell, kein API-Key nötig) ===
# URL wenn Ollama auf anderem Rechner läuft:
# OLLAMA_URL=http://localhost:11434
